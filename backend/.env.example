# Copy this file to backend/.env and fill in your key.
GEMINI_API_KEY=your-gemini-api-key-here

# Optional overrides (defaults shown)
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Optional: path to a trained classifier checkpoint. If unset, the
# pipeline falls back to a mock low-confidence prediction so the
# RAG/LLM layer can be developed/tested before training finishes.
# MODEL_CHECKPOINT_PATH=backend/models/saved/models/<name>/<run>/model_best.pth
# MODEL_CONFIG_PATH=backend/models/config3.json
