{
    "name": "PlantVillage_GoogLeNet_2",
    "n_gpu": 1,
    "arch": {
        "type": "GoogLeNetPlant",
        "args": {
            "num_classes": 38,
            "pretrained": true
        }
    },
    "data_loader": {
        "type": "PlantVillageDataLoader",
        "args": {
            "data_dir": "/mnt/d/Project/QI/AgriSage/dataset/plantvillage_prepared2",
            "batch_size": 24,
            "shuffle": true,
            "validation_split": 0.0,
            "num_workers": 8
        }
    },
    "optimizer": {
        "type": "SGD",
        "args": {
            "lr": 0.005,
            "momentum": 0.9,
            "weight_decay": 0.0005
        }
    },
    "loss": "googlenet_loss",
    "metrics": [
        "accuracy",
        "macro_f1"
    ],
    "lr_scheduler": {
        "type": "StepLR",
        "args": {
            "step_size": 10,
            "gamma": 0.1
        }
    },
    "trainer": {
        "epochs": 30,
        "save_dir": "saved/",
        "save_period": 1,
        "verbosity": 2,

        "monitor": "max val_accuracy",
        "early_stop": 0,

        "tensorboard": true
    }
}
